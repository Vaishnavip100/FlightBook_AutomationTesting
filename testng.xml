<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FlightBookingSuite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.RetryListener"/>
    </listeners>

    <test name="Flight Search Tests">
        <classes>
            <class name="tests.FlightSearchTest"/>
        </classes>
    </test>

    <test name="Flight Selection Tests">
        <classes>
            <class name="tests.FlightSelectionTest"/>
        </classes>
    </test>

    <test name="Purchase Tests">
        <classes>
            <class name="tests.PurchaseTest"/>
        </classes>
    </test>

    <test name="Route Search Tests">
        <classes>
            <class name="tests.DifferentRouteSearchTest"/>
        </classes>
    </test>

    <test name="Form Validation Tests">
        <classes>
            <class name="tests.FormValidationTest"/>
        </classes>
    </test>

</suite>